generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  Admin
  User
}

enum MembershipType {
  Free
  Premium
}

enum DocumentStatus {
  Pending
  Approved
  Rejected
}

enum TransactionType {
  Upload_Reward
  Download_Cost
  Subscription_Purchase
}

enum TransactionStatus {
  Pending
  Completed
  Failed
}

model User {
  id              String          @id @default(cuid())
  email           String          @unique
  emailVerified   DateTime?       @map("email_verified")
  passwordHash    String?         @map("password_hash")
  role            UserRole        @default(User)
  membershipType  MembershipType  @default(Free) @map("membership_type")
  premiumUntil    DateTime?       @map("premium_until")
  credits         Int             @default(0)
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")

  documents       Document[]
  transactions    Transaction[]
  accounts        Account[]
  sessions        Session[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Category {
  id        String     @id @default(cuid())
  name      String     @unique
  slug      String     @unique
  documents Document[]

  @@map("categories")
}

model Document {
  id              String         @id @default(cuid())
  title           String
  description     String?
  slug            String         @unique
  fileUrl         String         @map("file_url")
  previewPattern  String?        @map("preview_pattern")
  totalPages      Int            @default(0) @map("total_pages")
  status          DocumentStatus @default(Pending)
  viewCount       Int            @default(0) @map("view_count")
  downloadCount   Int            @default(0) @map("download_count")
  pointsRequired  Int            @default(0) @map("points_required")
  userId          String         @map("user_id")
  categoryId      String         @map("category_id")
  createdAt       DateTime       @default(now()) @map("created_at")

  uploader        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  category        Category       @relation(fields: [categoryId], references: [id], onDelete: Restrict)

  @@map("documents")
}

model Transaction {
  id          String            @id @default(cuid())
  userId      String            @map("user_id")
  type        TransactionType
  points      Int               @default(0)
  amount      Decimal?          @db.Decimal(10, 2)
  status      TransactionStatus @default(Pending)
  createdAt   DateTime          @default(now()) @map("created_at")

  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("transactions")
}
